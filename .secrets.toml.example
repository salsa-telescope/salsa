# .secrets.toml.example
#
# Copy to .secrets.toml and fill in real values.
# This file is intentionally NOT gitignored — .secrets.toml is.
#
# All sections are optional. The server starts without any credentials,
# but login will not be available unless at least one auth_provider is configured.

# --- OAuth2 authentication providers ---
#
# Each key under [auth_provider] becomes a named provider shown on the login page.
# Multiple providers can be defined.
#
# Optional `description` field: short text shown next to the provider button
# on the login page (e.g. notes about which accounts are accepted).
#
# Example: GitHub OAuth2 app
# Register at https://github.com/settings/developers → OAuth Apps
# Set the callback URL to: https://your-domain/auth/authorized

# [auth_provider.github]
# auth_uri             = "https://github.com/login/oauth/authorize"
# token_uri            = "https://github.com/login/oauth/access_token"
# redirect_uri         = "https://your-domain/auth/authorized"
# user_uri             = "https://api.github.com/user"
# id_field             = "id"
# display_name_field   = "login"
# scopes               = ["read:user"]
# client_id            = "your-github-client-id"
# client_secret        = "your-github-client-secret"

# Example: Discord OAuth2 app
# Register at https://discord.com/developers/applications

# [auth_provider.discord]
# auth_uri             = "https://discord.com/api/oauth2/authorize"
# token_uri            = "https://discord.com/api/oauth2/token"
# redirect_uri         = "https://your-domain/auth/authorized"
# user_uri             = "https://discord.com/api/users/@me"
# id_field             = "id"
# display_name_field   = "username"
# scopes               = ["identify"]
# client_id            = "your-discord-client-id"
# client_secret        = "your-discord-client-secret"

# Example: Google OAuth2 app
# Register at https://console.cloud.google.com → APIs & Services → Credentials
# Set the callback URL to: https://your-domain/auth/authorized

# [auth_provider.google]
# auth_uri             = "https://accounts.google.com/o/oauth2/v2/auth"
# token_uri            = "https://oauth2.googleapis.com/token"
# redirect_uri         = "https://your-domain/auth/authorized"
# user_uri             = "https://www.googleapis.com/oauth2/v2/userinfo"
# id_field             = "id"
# display_name_field   = "email"
# scopes               = ["openid", "email", "profile"]
# client_id            = "your-google-client-id.apps.googleusercontent.com"
# client_secret        = "your-google-client-secret"

# Example: Microsoft (Azure AD / Entra ID) OAuth2 app
# Register at https://portal.azure.com → Azure Active Directory → App registrations
# Set the callback URL to: https://your-domain/auth/authorized
# Replace {tenant-id} with your tenant ID, or use "common" for multi-tenant.

# [auth_provider.microsoft]
# auth_uri             = "https://login.microsoftonline.com/{tenant-id}/oauth2/v2.0/authorize"
# token_uri            = "https://login.microsoftonline.com/{tenant-id}/oauth2/v2.0/token"
# redirect_uri         = "https://your-domain/auth/authorized"
# user_uri             = "https://graph.microsoft.com/oidc/userinfo"
# id_field             = "sub"
# display_name_field   = "name"
# scopes               = ["openid"]
# client_id            = "your-azure-application-client-id"
# client_secret        = "your-azure-client-secret"
# description          = "Personal Microsoft accounts work directly. Work or school accounts may need approval from your IT admin before sign-in succeeds."

# --- Webcam ---
#
# Optional. If set, a snapshot from the webcam is shown on the live page
# and cropped per-telescope on the observe page (see webcam_crop in config.toml).

# [webcam]
# url      = "http://192.168.1.100"   # base URL of the camera (no trailing slash)
# username = "admin"
# password = "your-webcam-password"

[bookings]
max_upcoming_bookings = 6

[admin]
# User IDs (from the OAuth provider) that should have admin access.
user_ids = [1]

# Optional: IP or hostname of a webcam. Credentials go in .secrets.toml.
# [webcam]
# url = "https://192.168.1.100"

# --- Fake telescopes (useful for development / testing) ---

[[telescopes]]
name = "fake1"
enabled = true
location = [ 0.20802143022, 1.00170457462 ]
min_elevation = 0.087
stow_position = [ 90.0, 90.0 ]
telescope_type = "Fake"

[[telescopes]]
name = "fake2"
enabled = true
location = [ 0.20802143022, 1.00170457462 ]
min_elevation = 0.087
stow_position = [ 90.0, 90.0 ]
telescope_type = "Fake"

